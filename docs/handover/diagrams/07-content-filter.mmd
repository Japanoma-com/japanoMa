  'fontFamily': 'Helvetica Neue, Helvetica, Arial, sans-serif',
  'primaryColor': '#FAFAF7',
  'primaryTextColor': '#1A1816',
  'primaryBorderColor': '#3D5A7A',
  'lineColor': '#8A8279'
