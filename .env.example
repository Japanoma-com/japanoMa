# Japanoma Environment Variables
# Copy this file to .env.local and fill in the values

# Database (Drizzle ORM)
DATABASE_URL=postgresql://localhost:5432/japatak

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_WEBHOOK_SECRET=

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Lead capture: salted SHA-256 hashing of client IP for consent_records.ip_hash
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be the same value across all environments for the lifetime of the feature.
CONSENT_IP_HASH_SALT=replace-with-64-char-hex

# Transactional email (Resend) — used for lead + contact notifications to Go&C.
# If RESEND_API_KEY is not set, sends are skipped with a warn (dev-safe).
# Verified sending domain required in production.
RESEND_API_KEY=
EMAIL_FROM=Japanoma <noreply@japanoma.com.au>
EMAIL_NOTIFICATIONS_TO=kaz@goandc.com.au,shiun@goandc.com.au

# Admin UI feature gate — leave set to 'true' on staging/prod. The admin
# route subtree is also protected by Supabase app_metadata.is_admin on
# each user record.
AUTH_UI_ENABLED=true
